{
  "id": null,
  "title": "PredictiX — AI Prediction Monitoring",
  "uid": "predictix-main",
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["predictix", "ai", "ml"],
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(predictix_predictions_total)",
        "refId": "A"
      }],
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "#89b4fa", "mode": "fixed"}, "unit": "short"}}
    },
    {
      "id": 2,
      "title": "Predictions Per Disease",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum by (disease) (predictix_predictions_total)",
        "legendFormat": "{{disease}}",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "title": "Prediction Latency (p95)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "histogram_quantile(0.95, sum by (le, disease) (rate(predictix_prediction_duration_seconds_bucket[5m])))",
        "legendFormat": "{{disease}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "max": 10}}
    },
    {
      "id": 4,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum by (route) (rate(predictix_http_request_duration_seconds_count[1m]))",
        "legendFormat": "{{route}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 5,
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "process_resident_memory_bytes / 1024 / 1024",
        "legendFormat": "RSS Memory (MB)",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "mbytes"}}
    },
    {
      "id": 6,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "nodejs_eventloop_lag_seconds",
        "legendFormat": "Event Loop Lag",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "templating": {
    "list": [{
      "name": "DS_PROMETHEUS",
      "type": "datasource",
      "query": "prometheus",
      "current": {"value": "Prometheus"}
    }]
  }
}
